# Backend environment variables — copy to .env for local development.
# All values are OPTIONAL except CORS_ORIGINS in production.

# Comma-separated list of origins allowed to call this API.
# Use "*" for any origin (fine for a portfolio site with no auth).
# Restrict in production: e.g. "https://durrellsmith.onrender.com"
CORS_ORIGINS=*

# OPTIONAL — only required if you want the /api/status template endpoints
# to work. The portfolio (Behance proxy) doesn't use Mongo. Get a free
# connection string at https://www.mongodb.com/atlas if you need it.
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
# DB_NAME=portfolio
